{
    "rewrites": [
        {
            "source": "/i/:path*",
            "destination": "/api/img?p=:path*"
        },
        {
            "source": "/((?!api).*)",
            "destination": "/"
        }
    ],
    "buildCommand": "vite build",
    "outputDirectory": "dist",
    "framework": "vite",
    "headers": [
        {
            "source": "/(.*)",
            "headers": [{ "key": "X-Robots-Tag", "value": "noindex, nofollow" }]
        }
    ]
}
